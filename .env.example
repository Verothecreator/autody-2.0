# Autody environment template
# This file is safe to keep in GitHub because it contains placeholders only.
# Put real secrets in Render/VPS environment variables or a private .env file.

# Server
PORT=3000
REQUEST_BODY_LIMIT=18mb
APP_BASE_URL=https://autodytraded.com

# Supabase Postgres
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres
DB_POOL_MAX=3
DB_QUERY_TIMEOUT_MS=15000

# Supabase private storage for KYC uploads
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
KYC_STORAGE_BUCKET=autody-kyc
KYC_MAX_FILE_BYTES=8388608

# Live market/news refresh
LIVE_MARKET_REFRESH_MS=120000
LIVE_NEWS_REFRESH_MS=1800000
LIVE_CHART_REFRESH_SYMBOLS=BTC,ETH,SOL,SPY,QQQ,GLD,GC=F,CL=F
LIVE_CHART_REFRESH_RANGES=1d,1w,1m,3m,1y,all

# Google reCAPTCHA v2 checkbox
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
CAPTCHA_REQUIRED=true

# Email verification and sign-in codes
RESEND_API_KEY=
EMAIL_FROM="Autody <verify@mail.autodytraded.com>"
EMAIL_VERIFICATION_TTL_MS=86400000
LOGIN_EMAIL_CODE_TTL_MS=300000
SESSION_HOURS=8
REMEMBER_SESSION_HOURS=720
UNVERIFIED_ACCOUNT_RETENTION_DAYS=30

# Fiat funding processor
# Keep coming-soon/manual until a real processor is ready.
FIAT_PAYMENT_PROCESSOR=coming_soon
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Admin maintenance and one-admin console
ADMIN_RESET_KEY=
AUTODY_ADMIN_EMAIL=
AUTODY_ADMIN_PASSWORD=
AUTODY_ADMIN_SESSION_SECRET=
ADMIN_EMAIL_CODE_TTL_MS=300000
AUTODY_ADMIN_KEY_BYPASS=false

# Deposit address generation
# Preferred name is AUTODY_DEPOSIT_MNEMONIC.
# Old AUTODY_EVM_DEPOSIT_MNEMONIC still works, but do not use both.
AUTODY_DEPOSIT_MNEMONIC=
AUTODY_DEPOSIT_PASSWORD=
AUTODY_EVM_DEPOSIT_BASE_PATH=m/44'/60'/0'/0
DEPOSIT_ADDRESS_TTL_HOURS=24

# Deposit monitor
DEPOSIT_MONITOR_ENABLED=true
DEPOSIT_MONITOR_INTERVAL_MS=60000
DEPOSIT_MONITOR_ADDRESS_LIMIT=500
DEPOSIT_MIN_CONFIRMATIONS=3
DEPOSIT_MIN_AUTO_CREDIT_USD=0.01
DEPOSIT_MIN_AUTO_STABLECOIN_CREDIT=0.01
DEPOSIT_DUST_CLEANUP_LIMIT=250
DEPOSIT_EVM_LOG_LOOKBACK_BLOCKS=5000
DEPOSIT_EVM_SCAN_OVERLAP_BLOCKS=250
DEPOSIT_EVM_LOG_SCAN_CHUNK_BLOCKS=5000
DEPOSIT_EVM_TOPIC_ADDRESS_BATCH_SIZE=80
DEPOSIT_NATIVE_LOOKBACK_BLOCKS=120
DEPOSIT_NATIVE_BLOCK_SCAN_LIMIT=40
DEPOSIT_ACCOUNT_TX_LIMIT=100
DEPOSIT_REST_TIMEOUT_MS=12000

# Chain RPC/API providers
# These are optional, but private provider URLs are more reliable than public endpoints.
POLYGON_RPC=
ETHEREUM_RPC_URL=
BSC_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
AVALANCHE_RPC_URL=
SOLANA_RPC_URL=
XRP_RPC_URL=
TRON_API_URL=
TRON_PRO_API_KEY=
STELLAR_HORIZON_URL=
BITCOIN_API_URL=
BCH_API_URL=
DOGE_API_URL=
LITECOIN_API_URL=

# Optional AU/controlled-market defaults
AUTODY_AU_START_PRICE=0.001
AUTODY_AU_DEFAULT_LIQUIDITY_USD=10000
AUTODY_AU_TRADE_MAX_IMPACT_PCT=3
AUTODY_AU_TRADE_IMPACT_MULTIPLIER=0.35
AU_MARKET_TICK_RETENTION_DAYS=400
AU_MARKET_TICK_MAX_ROWS=20000

# Existing optional Autody integrations
BACKEND_PK=
BUY_CONTRACT_ADDRESS=
TRANSAK_SECRET=
TOKEN_CONTRACT=
POOL_ADDRESS=
VAULT_ADDRESS=
WALLETCONNECT_PROJECT_ID=
TRANSAK_API_KEY=
TRANSAK_ENV=
GOOGLE_SHEET_URL=
