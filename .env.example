# Server
PORT=3000

# Supabase Postgres connection string.
# Use the pooled connection string from Supabase, then paste it into Render as DATABASE_URL.
DATABASE_URL=postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres

# Optional live-data refresh timers. Set either to 0 to disable.
LIVE_MARKET_REFRESH_MS=300000
LIVE_NEWS_REFRESH_MS=1800000
LIVE_CHART_REFRESH_SYMBOLS=BTC,ETH,SOL,SPY,QQQ,GLD,GC=F,CL=F
LIVE_CHART_REFRESH_RANGES=1d,1w,1m,3m,1y,all

# Google reCAPTCHA v2 checkbox human verification.
# Add these in Render after creating a Google reCAPTCHA v2 "I'm not a robot" widget.
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
CAPTCHA_REQUIRED=true

# Email-only account verification delivery.
APP_BASE_URL=https://autody-2-0.onrender.com
RESEND_API_KEY=
EMAIL_FROM="Autody <verify@mail.autodytraded.com>"

# Fiat funding processor. Debit card and ACH use Stripe Checkout when configured.
# Wire requests stay as tracked references until bank instructions are connected.
FIAT_PAYMENT_PROCESSOR=stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional one-time admin cleanup key for protected maintenance routes.
ADMIN_RESET_KEY=

# One-admin ops gateway. Use your own email and a strong private password in Render.
AUTODY_ADMIN_EMAIL=
AUTODY_ADMIN_PASSWORD=
AUTODY_ADMIN_SESSION_SECRET=
ADMIN_EMAIL_CODE_TTL_MS=300000
# Keep false so normal admin pages require email + password + email code.
AUTODY_ADMIN_KEY_BYPASS=false

# Existing optional Autody integrations
POLYGON_RPC=
BACKEND_PK=
BUY_CONTRACT_ADDRESS=
TRANSAK_SECRET=
TOKEN_CONTRACT=
POOL_ADDRESS=
VAULT_ADDRESS=
WALLETCONNECT_PROJECT_ID=
TRANSAK_API_KEY=
TRANSAK_ENV=
GOOGLE_SHEET_URL=
